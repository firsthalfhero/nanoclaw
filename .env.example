# ─────────────────────────────────────────────
# NanoClaw — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────

# ── Claude / Anthropic ──────────────────────
# Use ONE of the two auth methods below.

# Option A: API key (preferred for self-hosted)
# ANTHROPIC_API_KEY=

# Option B: OAuth token (if you use claude.ai login)
CLAUDE_CODE_OAUTH_TOKEN=

# ── NanoClaw Core ───────────────────────────
# The name your assistant responds to (e.g. @Andy in chat)
ASSISTANT_NAME=Andy

# ── Telegram ────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ── Google Gemini (voice/audio transcription) ─
# Get a key at: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=

# ── OpenAI ───────────────────────────────────
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Brave Search ────────────────────────────
# Get a key at: https://brave.com/search/api/
BRAVE_API_KEY=

# ── Motion Task Manager ─────────────────────
# https://developer.usemotion.com/
MOTION_API_KEY=
MOTION_WORKSPACE_ID=

# ── Google Calendar ─────────────────────────
# Create a project at https://console.cloud.google.com/,
# enable the Calendar API, and create OAuth credentials
# for "TV and Limited Input Devices" (device flow).
# Run: python3 container/skills/google-calendar/scripts/gcal.py auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Gmail ────────────────────────────────────
# Requires a SEPARATE OAuth client of type "Desktop app" (not TV/device flow).
# Same Google Cloud project as Calendar is fine — just create a second client.
# Enable the Gmail API, create Desktop app credentials, then run:
# Run: python groups/main/auth_setup_gmail.py
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Mobility Tracker
FIREBASE_SERVICE_ACCOUNT=

IMAP_PASSWORD_GEORGE_ICLOUD=xxxx-xxxx-xxxx-xxxx
IMAP_PASSWORD_HENRY_ICLOUD=xxxx-xxxx-xxxx-xxxx
IMAP_PASSWORD_SOPHIE_ICLOUD=xxxx-xxxx-xxxx-xxxx
